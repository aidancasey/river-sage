# Copy this file to .env.secrets and fill in your values.
# .env.secrets is gitignored and never committed.

# Dash0 observability
DASH0_AUTH_TOKEN=

# Twilio WhatsApp alerts
# Account SID and Auth Token from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender number in the format: whatsapp:+14155238886
# Use the Twilio sandbox number for testing, or your approved WhatsApp sender for production.
TWILIO_WHATSAPP_FROM=

# CORS origin for the alerts API — comma-separated list of allowed origins
# Set to your web app URL to prevent other sites from calling the alerts endpoints
# e.g. https://riverguru.ie or http://river-guru-web-production.s3-website-eu-west-1.amazonaws.com
ALLOWED_ORIGIN=
