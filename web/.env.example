# River Guru Web App Environment Configuration

# API Gateway endpoint URL
# For production: Use your deployed API Gateway URL
# For development: Can use http://localhost:3000 for local testing
VITE_API_BASE_URL=https://your-api-gateway-url.execute-api.region.amazonaws.com/production

# Example for local development:
# VITE_API_BASE_URL=http://localhost:3000

# Flagsmith environment ID for feature flags
# Get this from your Flagsmith project settings
VITE_FLAGSMITH_ENVIRONMENT_ID=your-flagsmith-environment-id
